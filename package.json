{
  "name": "wristcord",
  "author": "dot-Justin",
  "version": "1.0.0",
  "keywords": ["pebble-app"],
  "private": true,
  "dependencies": { "pebble-clay": "^1.0.4" },
  "scripts": { "test": "node --test 'test/**/*.test.js'" },
  "pebble": {
    "displayName": "Wristcord",
    "description": "Discord on your wrist! Browse your servers, follow chats, and send a reply with your voice, right from Pebble Time 2. Heads up, Wristcord is a selfbot; by using it you accept that selfbotting is against Discord ToS.",
    "category": "Communication",
    "uuid": "da8247b9-80ed-4af8-968f-33b79d2a0483",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": ["emery"],
    "watchapp": { "watchface": false },
    "capabilities": ["configurable"],
    "messageKeys": [
      "OP", "ID", "PAGE", "MORE", "COUNT", "TEXT", "ERR",
      "READY", "SET_THEME", "SET_ACCENT", "SET_POLL", "HAS_TOKEN", "CONSENT", "ROWS",
      "SET_DM_COUNT", "SET_SERVER_COUNT", "HOME_REFRESH", "SET_SORT_MODE"
    ],
    "resources": {
      "media": [
        { "type": "bitmap", "name": "MENU_ICON", "file": "images/menu_icon.png", "menuIcon": true },
        { "type": "bitmap", "name": "DISCORD_LOGO", "file": "images/discord_logo.png" }
      ]
    }
  }
}
